  <path d="M 256 80 L 280 180 L 340 140 L 300 200 L 400 224 L 300 248 L 340 308 L 280 268 L 256 368 L 232 268 L 172 308 L 212 248 L 112 224 L 212 200 L 172 140 L 232 180 Z" 
        fill="#ff7f3f" 
